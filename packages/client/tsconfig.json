{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020"],
    "types": ["node"],
    "skipLibCheck": true,

    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,

    "moduleResolution": "bundler",
    "isolatedModules": true,
    "moduleDetection": "force",

    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "src/__tests__"]
}
