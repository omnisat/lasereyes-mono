{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "build/**", "docs/**", "docs/dist/**", "dist/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "size": {
      "dependsOn": ["build"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "docs:typedoc": {
      "dependsOn": ["^build"],
      "inputs": ["packages/*/src/**"],
      "outputs": ["apps/docs/.typedoc-output/**"]
    },
    "docs:build": {
      "dependsOn": ["docs:typedoc"],
      "outputs": [".next/**"]
    },
    "docs:dev": {
      "dependsOn": ["docs:typedoc"],
      "cache": false,
      "persistent": true
    },
    "apps/**": {
      "dependsOn": ["packages/**"]
    },
    "packages/**": {
      "outputs": ["dist/**"]
    }
  }
}
